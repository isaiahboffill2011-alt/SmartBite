{
  "$schema": "https://json.schemastore.org/vercel",
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build --workspaces",
  "outputDirectory": "client/dist",
  "cleanUrls": true,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://smartbite-api.vercel.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

